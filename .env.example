# App
APP_ENV=development
SECRET_KEY=change-me-to-a-64-char-random-string
API_KEY_HEADER=X-API-Key

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=civic_agent
POSTGRES_USER=civic
POSTGRES_PASSWORD=change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Confidence threshold (Phase 2 — stored here, not hardcoded)
VISION_CONFIDENCE_THRESHOLD=0.75

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
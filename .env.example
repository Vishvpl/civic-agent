# App
APP_ENV=development
SECRET_KEY=change-me-to-a-64-char-random-string
API_KEY_HEADER=X-API-Key

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=civic_agent
POSTGRES_USER=civic
POSTGRES_PASSWORD=change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Confidence threshold (Phase 2 — stored here, not hardcoded)
VISION_CONFIDENCE_THRESHOLD=0.75

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO

# AI Model Providers
QWEN_API_KEY=your-qwen-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=your-groq-key-here

# Groq
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=2

# MCP tools
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
MUNICIPAL_EMAIL=civic@yourmunicipalcorp.gov

GEOCODING_API_URL=https://nominatim.openstreetmap.org/reverse
GEOCODING_USER_AGENT=CivicAgent/1.0